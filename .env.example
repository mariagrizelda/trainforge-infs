DJANGO_SECRET_KEY=replace-me-in-production
DJANGO_DEBUG=1

# OpenAI (for the AI plan generator)
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-5.4-mini

# Google OAuth (for the "Continue with Google" button on login/signup).
# Leave blank to hide the button. Steps to populate:
#   1. https://console.cloud.google.com/apis/credentials -> Create credentials -> OAuth client ID -> Web application
#   2. Authorised JavaScript origin:  http://localhost:8000
#   3. Authorised redirect URI:       http://localhost:8000/accounts/google/login/callback/
#   4. Copy the client ID + secret into the two lines below.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
