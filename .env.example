DJANGO_SECRET_KEY=replace-me-in-production
DJANGO_DEBUG=1

OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-5.4-mini

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Production-only. Leave blank in dev.
# URL_PREFIX is the sub-path TrainForge is mounted under in nginx.
# Setting this also automatically prefixes STATIC_URL and MEDIA_URL.
URL_PREFIX=
ALLOWED_HOSTS=
CSRF_TRUSTED_ORIGINS=

# Database. Leave DB_ENGINE blank (or set to "sqlite") to keep using the
# SQLite file. Set DB_ENGINE=mysql and fill the rest to use MySQL on the
# zone (see DEPLOY.md).
DB_ENGINE=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
